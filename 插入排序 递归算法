 #include<iostream>
using namespace std;

void Insert_Sort(int A[],int n)
 {
    if(n>1)
    {
        Insert_Sort(A,n-1); //递归将前面n-1个元素排序好
        // 你的代码，把第n个元素插入到前面n-1个元素中
        int key = A[n-1];
        int j = n-2;
        while(j>=0 && A[j]>key){
            A[j+1] = A[j];
            j--;
        }
        A[j+1] = key;
    }
}

int main()
{
    int n,num[1000];
    cin>>n;
    
    // 你的代码
    for(int i=0;i<n;i++){
        cin >> num[i];
    }
    Insert_Sort(num,n);
    for(int i=0;i<n-1;i++){
        cout << num[i] << " ";
    }
    cout << num[n-1];
	return 0;
}
